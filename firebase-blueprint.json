{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform, either a buyer or a seller.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller"] },
        "storeId": { "type": "string", "description": "ID of the store if the user is a seller" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Store": {
      "title": "Store",
      "description": "A seller's store on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "An archival piece listed in a store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "storeId", "name", "price", "category", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store details"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    }
  }
}
